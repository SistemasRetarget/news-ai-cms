# Database (PostgreSQL)
DATABASE_URL=postgresql://news:news@localhost:5432/news_db
# Force SSL on the pg pool (auto-detected for Railway/Neon/Supabase/Heroku/
# RDS/Azure/DO URLs). Set to "true" to force or "false" to disable.
# DATABASE_SSL=true

# Payload
PAYLOAD_SECRET=your-secret-key-here

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site profile (multi-site mode)
# Options: news-ai (default, full news+AI), blog-simple (manual blog), agency (landings+analyzer)
SITE_PROFILE=news-ai

# Logging
LOG_LEVEL=debug

# Sentry (optional crash reporting - disabled if DSN empty)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Rate Limiting (Upstash Redis - optional, falls back to in-memory)
# Get credentials from https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=56912345678

# Environment
NODE_ENV=development
PORT=3000
