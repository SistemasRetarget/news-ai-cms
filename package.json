{
  "name": "news-ai-cms",
  "version": "0.1.0",
  "description": "Blog de noticias con recolección AI",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "bash scripts/setup.sh",
    "test": "playwright test tests/",
    "test:articles": "playwright test tests/articles.spec.ts",
    "test:categories": "playwright test tests/categories.spec.ts",
    "test:sources": "playwright test tests/sources.spec.ts",
    "test:landing-pages": "playwright test tests/landing-pages.spec.ts",
    "test:users": "playwright test tests/users.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "format": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.0",
    "@payloadcms/next": "^3.84.0",
    "@payloadcms/richtext-lexical": "^3.84.0",
    "@payloadcms/ui": "^3.84.0",
    "@sentry/nextjs": "^10.49.0",
    "@upstash/redis": "^1.37.0",
    "cheerio": "^1.2.0",
    "graphql": "^16.13.2",
    "next": "~15.4.11",
    "payload": "^3.84.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "20.14.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "10.4.19",
    "better-sqlite3": "^12.9.0",
    "cross-env": "^7.0.3",
    "eslint": "8.57.0",
    "eslint-config-next": "~15.4.11",
    "pino-pretty": "^13.1.3",
    "postcss": "8.4.40",
    "prettier": "3.3.3",
    "sass": "^1.99.0",
    "sharp": "0.33.4",
    "tailwindcss": "3.4.7",
    "tsx": "^4.21.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
